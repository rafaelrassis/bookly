# Postgres — em produção aponte para Vercel Postgres, Railway, RDS, etc.
DATABASE_URL="postgresql://user:password@localhost:5432/bookly?schema=public"

# conexão direta (sem pgbouncer/pooler), usada só pelo Prisma Migrate.
# em provedores sem pooler (ex: local, RDS) pode repetir o valor acima;
# no Neon é a connection string do host sem "-pooler".
DIRECT_URL="postgresql://user:password@localhost:5432/bookly?schema=public"

# gerar com: npx auth secret
AUTH_SECRET=""

# dev: e-mails de verificação/reset vão pro console (sem SENDGRID_API_KEY).
# prod: configurar SENDGRID_API_KEY + MAIL_FROM.
# SENDGRID_API_KEY=""
# MAIL_FROM=""
